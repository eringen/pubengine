{
  "name": "{{.ProjectName}}",
  "private": true,
  "scripts": {
    "css": "tailwindcss -i assets/tailwind.css -o public/tailwind.css --minify",
    "css:watch": "tailwindcss -i assets/tailwind.css -o public/tailwind.css --watch",
    "js": "esbuild src/app.js --bundle --minify --outfile=public/app.min.js",
    "js:watch": "esbuild src/app.js --bundle --outfile=public/app.min.js --watch",
    "build": "npm run css && npm run js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tailwindcss": "^3.4.0"
  }
}

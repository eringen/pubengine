package views

import (
	"github.com/eringen/pubengine"
)

// Home renders the full home page with blog listing.
templ Home(posts []pubengine.BlogPost, activeTag string, tags []string, siteURL string) {
	<!DOCTYPE html>
	<html lang="en" class="bg-white">
		@Head("{{.SiteName}}")
		<body class="min-h-screen bg-white text-gray-900">
			@Nav("{{.SiteName}}")
			<main id="content" receiver="content" class="max-w-3xl mx-auto px-4 py-8">
				@BlogSection(posts, activeTag, tags)
			</main>
			@Footer("{{.SiteName}}")
			@JsonLD(pubengine.WebsiteJsonLD(pubengine.SiteConfig{Name: "{{.SiteName}}", URL: siteURL}))
		</body>
	</html>
}

// HomePartial renders the home page content for talkDOM partial updates.
templ HomePartial(posts []pubengine.BlogPost, activeTag string, tags []string, siteURL string) {
	<title>{{.SiteName}}</title>
	<main id="content" receiver="content" class="max-w-3xl mx-auto px-4 py-8">
		@BlogSection(posts, activeTag, tags)
	</main>
}

// BlogSection renders the blog post listing with tag filter.
templ BlogSection(posts []pubengine.BlogPost, activeTag string, tags []string) {
	<div id="blog-section" receiver="blogSection">
		if len(tags) > 0 {
			<div class="flex flex-wrap gap-2 mb-8">
				<a
					href="/"
					sender="blogSection get: /?partial=blog apply: outer"
					push-url="/"
					if activeTag == "" {
						class="px-3 py-1 text-sm rounded-full bg-gray-900 text-white"
					} else {
						class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200"
					}
				>
					All
				</a>
				for _, tag := range tags {
					<a
						href={ templ.SafeURL("/?tag=" + pubengine.PathEscape(tag)) }
						sender={ "blogSection get: /?tag=" + pubengine.PathEscape(tag) + "&partial=blog apply: outer" }
						push-url={ "/?tag=" + pubengine.PathEscape(tag) }
						if tag == activeTag {
							class="px-3 py-1 text-sm rounded-full bg-gray-900 text-white"
						} else {
							class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200"
						}
					>
						{ tag }
					</a>
				}
			</div>
		}
		if len(posts) == 0 && activeTag == "" {
			@Welcome()
		} else if len(posts) == 0 {
			<p class="text-gray-500">No posts found.</p>
		}
		<div class="space-y-8">
			for _, post := range posts {
				<article class="group">
					<a
						href={ templ.SafeURL(post.Link + "/") }
						sender={ "content get: " + post.Link + "/?partial=post apply: outer" }
						push-url={ post.Link + "/" }
						class="block"
					>
						<h2 class="text-xl font-semibold group-hover:text-blue-600">
							{ post.Title }
						</h2>
						<time class="text-sm text-gray-500">{ post.Date }</time>
						if post.Summary != "" {
							<p class="mt-2 text-gray-600">{ post.Summary }</p>
						}
					</a>
					if len(post.Tags) > 0 {
						<div class="mt-2 flex gap-2">
							for _, tag := range post.Tags {
								<span class="text-xs px-2 py-0.5 bg-gray-100 rounded text-gray-600">{ tag }</span>
							}
						</div>
					}
				</article>
			}
		</div>
	</div>
}

// Welcome renders the default landing page for a fresh pubengine install.
templ Welcome() {
	<section class="py-24 text-center">
		<h1 class="text-6xl font-bold tracking-tight md:text-8xl text-gray-900">
			pubEngine
		</h1>
		<p class="mt-4 text-lg text-gray-500">
			small publishing engine
		</p>
		<p class="mt-8 text-sm font-semibold uppercase tracking-widest text-green-600">
			it works!
		</p>
		<div class="mt-12 text-sm text-gray-400">
			<p>Head to <a href="/admin/" class="underline hover:text-gray-600">/admin</a> to write your first post.</p>
		</div>
	</section>
}
